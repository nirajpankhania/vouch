{
  "name": "vouch-cli",
  "version": "1.0.1",
  "description": "Intent-aware verification for AI-generated code. You tell it what you asked for; it tells you what you actually got.",
  "type": "module",
  "bin": {
    "vouch": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . && tsc --noEmit",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "keywords": [
    "ai",
    "code-review",
    "verification",
    "claude",
    "cli",
    "diff"
  ],
  "author": "Niraj Pankhania",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nirajpankhania/vouch.git"
  },
  "homepage": "https://github.com/nirajpankhania/vouch#readme",
  "bugs": {
    "url": "https://github.com/nirajpankhania/vouch/issues"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "commander": "^15.0.0",
    "parse-diff": "^0.12.0",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.4",
    "simple-git": "^3.36.0",
    "ts-morph": "^28.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@types/picomatch": "^4.0.3",
    "eslint": "^10.4.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
