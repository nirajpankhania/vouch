{
  "name": "vouch-cli",
  "version": "0.0.0",
  "description": "Intent-aware verification for AI-generated code. You tell it what you asked for; it tells you what you actually got.",
  "type": "module",
  "bin": {
    "vouch": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . && tsc --noEmit"
  },
  "keywords": [
    "ai",
    "code-review",
    "verification",
    "claude",
    "cli",
    "diff"
  ],
  "author": "Niraj Pankhania",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nirajpankhania/vouch.git"
  },
  "dependencies": {
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "eslint": "^10.4.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
